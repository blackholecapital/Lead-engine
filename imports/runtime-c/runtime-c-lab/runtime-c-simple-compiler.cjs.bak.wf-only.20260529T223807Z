    `${root}/factory/manuals/02_WORKER_MANUAL_V6_7_C.md`,
    `${root}/factory/indexes/FACTORY_INDEX.json`
  ];

  const lane={
    HTML:{worker:"Worker A",files:[`${root}/factory/manuals/WA_HTML_WORKER.md`,`${root}/factory/indexes/HTML_INDEX.json`]},
    CSS:{worker:"Worker B",files:[`${root}/factory/manuals/WB_CSS_WORKER.md`,`${root}/factory/indexes/CSS_INDEX.json`]},
    JS:{worker:"Worker C",files:[`${root}/factory/manuals/WC_JS_WORKER.md`,`${root}/factory/indexes/JS_INDEX.json`]},
