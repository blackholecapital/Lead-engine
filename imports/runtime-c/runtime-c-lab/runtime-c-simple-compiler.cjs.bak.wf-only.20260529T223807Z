#!/usr/bin/env node
const fs=require("fs");
const path=require("path");

const input=process.argv[2];
const output=process.argv[3];

if(!input||!output){
  console.error("usage: runtime-c-simple-compiler.cjs <simple.json> <full.json>");
  process.exit(2);
}

const s=JSON.parse(fs.readFileSync(input,"utf8"));
const objective_delta=String(s.objective_delta||s.objective||"");

function fail(error, extra={}){
  console.error(JSON.stringify({ok:false,error,...extra},null,2));
  process.exit(1);
}

for(const k of ["mode","pass","objective","job_name","title","pod","lane_cell_backend"]){
  if(s[k]===undefined||s[k]===null||String(s[k]).trim()===""){
    fail("MISSING_REQUIRED_FIELD",{field:k});
  }
}

const mode=String(s.mode);
const pass=Number(s.pass);
const family=String(s.family||s.product_slug||s.job_name||s.title);
const pod=String(s.pod).toUpperCase();
const backend=String(s.lane_cell_backend).toUpperCase();
const objective=String(s.objective).replace(/\s+/g," ").trim();

if(mode==="iteration_pass"){
  if(!s.parent_context?.source_output){
    fail("MISSING_PARENT_CONTEXT",{mode,pass,family});
  }
  for(const f of ["index.html","styles.css","app.js"]){
    const p=path.join(s.parent_context.source_output,f);
    if(!fs.existsSync(p)){
      fail("PARENT_FILE_MISSING",{file:p});
    }
  }
}


