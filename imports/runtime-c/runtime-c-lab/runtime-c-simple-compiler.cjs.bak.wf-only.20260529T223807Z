  }[laneRole];

  const files=[...common,...(lane?.files||[])];

  return `You are ${lane?.worker || "a Runtime-C worker"}.

Read before beginning work:
${files.map(f=>`- ${f}`).join("\n")}

Existing compiler prompt begins below.
`;
}

function laneTask(mode, laneRole, objective, objectiveDelta, parentPath, businessTitle){
  const header=workerBootstrap(laneRole);
  const objectiveText = mode==="iteration_pass" ? objectiveDelta : objective;

  const parentBlock = mode==="iteration_pass"
    ? `
PARENT CONTEXT:
${parentPath}

PRESERVATION REQUIREMENTS:
Load and preserve parent output.
Keep existing structure, IDs, classes, behavior, content, and working features unless objective delta explicitly says to replace them.
`
    : "";

  return `
${header}

${BASE_WORKER_PROMPT}

PRODUCT TITLE:
${businessTitle}

${passModeContract(mode)}

${parentBlock}

OBJECTIVE:
${objectiveText}

${laneContract(laneRole)}

OUTPUT:
Return only the artifact required for lane ${laneRole}.
`.trim();
}


